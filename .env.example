# ============================================
#   النجارة الحديثة - Server Environment Variables
#   Copy this file to .env and fill in your values
# ============================================

# ── Server ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────
# Get this from: https://cloud.mongodb.com
# Create a free cluster → Connect → Drivers → copy the URI
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/najara?retryWrites=true&w=majority

# ── JWT Secret ──────────────────────────────
# Generate a strong random string (min 32 chars)
# You can run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random
JWT_EXPIRES_IN=7d

# ── Admin Credentials (first-time seed) ─────
# These are used ONCE to seed the admin user in MongoDB
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123

# ── Cloudinary (for image uploads) ──────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Client URL (for CORS) ───────────────────
CLIENT_URL=http://localhost:3000
